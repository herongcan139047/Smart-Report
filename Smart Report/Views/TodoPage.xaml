<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Smart_Report.Views.TodoPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Todos">

    <VerticalStackLayout Padding="16" Spacing="10">
        <HorizontalStackLayout Spacing="8">
            <Entry x:Name="TodoEntry" Placeholder="Add a todo..." HorizontalOptions="FillAndExpand"/>
            <Button Text="Add" Clicked="OnAddClicked"/>
        </HorizontalStackLayout>

        <CollectionView x:Name="TodoList">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <SwipeView>
                        <SwipeView.RightItems>
                            <SwipeItems Mode="Reveal">
                                <SwipeItem Text="Delete" BackgroundColor="Tomato"
                                           Invoked="OnDeleteInvoked"
                                           CommandParameter="{Binding .}" />
                            </SwipeItems>
                        </SwipeView.RightItems>

                        <Grid Padding="8" ColumnDefinitions="Auto,*">
                            <CheckBox IsChecked="{Binding IsDone}" CheckedChanged="OnCheckedChanged"
                                      VerticalOptions="Center" />
                            <Label Grid.Column="1"
                                   Text="{Binding Text}"
                                   VerticalOptions="Center" />
                        </Grid>
                    </SwipeView>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </VerticalStackLayout>
</ContentPage>