<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Smart_Report.Views.RegisterPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Register">

	<ScrollView>
		<VerticalStackLayout Padding="20" Spacing="12">
			<Label Text="Register" FontSize="28" />

			<Entry x:Name="EmailEntry" Placeholder="Email" Keyboard="Email" />
			<Entry x:Name="NameEntry" Placeholder="Display name (optional)" />
			<Entry x:Name="PasswordEntry" Placeholder="Password" IsPassword="True" />

			<Button Text="Create Account" Clicked="OnRegisterClicked" />
			<Label x:Name="MsgLabel" TextColor="OrangeRed" />
		</VerticalStackLayout>
	</ScrollView>
</ContentPage>