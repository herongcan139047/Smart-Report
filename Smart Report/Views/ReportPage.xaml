<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Smart_Report.Views.ReportPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Report">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="10">

            <Label Text="Create Report"
                   FontSize="24"
                   FontAttributes="Bold" />

            <Entry x:Name="TitleEntry"
                   Placeholder="Title" />

            <Editor x:Name="DescEditor"
                    Placeholder="Description"
                    AutoSize="TextChanges"
                    HeightRequest="100" />

            <HorizontalStackLayout Spacing="8">
                <Button Text="Take Photo"
                        Clicked="OnTakePhotoClicked" />

                <Button Text="Get Location"
                        Clicked="OnGetLocationClicked" />

                <Button Text="Save"
                        Clicked="OnSaveClicked" />
            </HorizontalStackLayout>

            <Label x:Name="InfoLabel"
                   TextColor="Gray" />

            <Image x:Name="PreviewImage"
                   HeightRequest="180"
                   Aspect="AspectFill"
                   IsVisible="False" />

            <Label Text="History"
                   FontSize="18"
                   FontAttributes="Bold"
                   Margin="0,12,0,0" />

            <CollectionView x:Name="ReportList">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame Padding="10"
                               Margin="0,6"
                               BorderColor="Gray">

                            <VerticalStackLayout Spacing="6">

                                <Label Text="{Binding Title}"
                                       FontAttributes="Bold"
                                       FontSize="18" />

                                <Label Text="{Binding Description}"
                                       LineBreakMode="WordWrap"
                                       MaxLines="3" />

                                <Image Source="{Binding PhotoPath}"
                                       HeightRequest="180"
                                       Aspect="AspectFill"
                                       Margin="0,6,0,0">
                                    <Image.Triggers>
                                        <DataTrigger TargetType="Image"
                                                     Binding="{Binding PhotoPath}"
                                                     Value="">
                                            <Setter Property="IsVisible" Value="False" />
                                        </DataTrigger>
                                        <DataTrigger TargetType="Image"
                                                     Binding="{Binding PhotoPath}"
                                                     Value="{x:Null}">
                                            <Setter Property="IsVisible" Value="False" />
                                        </DataTrigger>
                                    </Image.Triggers>
                                </Image>

                                <Label Text="{Binding CreatedAt, StringFormat='Created: {0:yyyy-MM-dd HH:mm:ss}'}"
                                       FontSize="12"
                                       Opacity="0.7" />

                                <Label Text="{Binding UserId, StringFormat='Owner UserId: {0}'}"
                                       FontSize="12"
                                       Opacity="0.7" />

                                <Label FontSize="12" Opacity="0.7">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="Lat: " />
                                            <Span Text="{Binding Latitude}" />
                                            <Span Text="   Lng: " />
                                            <Span Text="{Binding Longitude}" />
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>

                                <Label Text="Status: Open"
                                       FontAttributes="Bold"
                                       FontSize="13">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label"
                                                     Binding="{Binding IsResolved}"
                                                     Value="True">
                                            <Setter Property="Text" Value="Status: Resolved" />
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>

                                <VerticalStackLayout Spacing="2">
                                    <VerticalStackLayout.Triggers>
                                        <DataTrigger TargetType="VerticalStackLayout"
                                                     Binding="{Binding IsResolved}"
                                                     Value="False">
                                            <Setter Property="IsVisible" Value="False" />
                                        </DataTrigger>
                                    </VerticalStackLayout.Triggers>

                                    <Label Text="{Binding ResolvedBy, StringFormat='Resolved by: {0}'}"
                                           FontSize="12"
                                           Opacity="0.8" />

                                    <Label Text="{Binding ResolvedAt, StringFormat='Resolved at: {0:yyyy-MM-dd HH:mm:ss}'}"
                                           FontSize="12"
                                           Opacity="0.8" />
                                </VerticalStackLayout>

                                <HorizontalStackLayout Spacing="8" Margin="0,6,0,0">

                                    <Button Text="Mark Resolved"
                                            Clicked="OnResolveClicked"
                                            CommandParameter="{Binding .}">
                                        <Button.Triggers>
                                            <DataTrigger TargetType="Button"
                                                         Binding="{Binding IsResolved}"
                                                         Value="True">
                                                <Setter Property="IsVisible" Value="False" />
                                            </DataTrigger>
                                        </Button.Triggers>
                                    </Button>

                                    <Button Text="Undo Resolved"
                                            Clicked="OnUnresolveClicked"
                                            CommandParameter="{Binding .}"
                                            IsVisible="False">
                                        <Button.Triggers>
                                            <DataTrigger TargetType="Button"
                                                         Binding="{Binding IsResolved}"
                                                         Value="True">
                                                <Setter Property="IsVisible" Value="True" />
                                            </DataTrigger>
                                        </Button.Triggers>
                                    </Button>

                                    <Button Text="Delete"
                                            Clicked="OnDeleteClicked"
                                            CommandParameter="{Binding .}" />

                                </HorizontalStackLayout>

                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>